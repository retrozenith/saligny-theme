# BEGIN WordPress
# ============================================================
# WordPress + SSL + Cloudflare Tunnel / Reverse Proxy
# ============================================================

# This .htaccess file is configured to work with WordPress when 
# it's behind a Cloudflare Tunnel or any reverse proxy that 
# terminates SSL and forwards requests to the backend

#!!! Warning: must add a2enmod module to apache2
# # Enable the rewrite module
# a2enmod rewrite
# # Restart Apache to apply changes
# service apache2 restart

# ------------------------------------------------------------
# 1. Tell Apache/PHP that the connection is HTTPS when the
#    request arrives through Cloudflare Tunnel or any reverse
#    proxy that sets X-Forwarded-Proto: https.
#    Without this WordPress generates http:// URLs and cookies
#    may lose the Secure flag.
# ------------------------------------------------------------
<IfModule mod_setenvif.c>
    SetEnvIf X-Forwarded-Proto "^https$" HTTPS=on
    SetEnvIf X-Forwarded-Proto "^https$" SERVER_PORT=443
</IfModule>

# ------------------------------------------------------------
# 2. WordPress rewrites
# ------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Propagate HTTPS env var from the X-Forwarded-Proto header
    RewriteCond %{HTTP:X-Forwarded-Proto} =https [NC]
    RewriteRule ^ - [E=HTTPS:on,E=SERVER_PORT:443]

    # Pass Authorization header so REST API / JWT auth works
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteBase /
    RewriteRule ^index\.php$ - [L]

    # Serve real files and directories directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule . /index.php [L]
</IfModule>

# ------------------------------------------------------------
# 3. Security headers
# ------------------------------------------------------------
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ------------------------------------------------------------
# 4. Block direct access to sensitive files
# ------------------------------------------------------------
<FilesMatch "^(wp-config\.php|readme\.html|license\.txt)$">
    Require all denied
</FilesMatch>

# Block dotfiles (.env, .git, etc.)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# END WordPress
